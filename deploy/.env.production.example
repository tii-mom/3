# =============================================================================
# 3API production-aligned env template (NO secrets)
# Source of truth on server: /opt/sub2api-deploy/.env
# Copy secrets only on the server; never commit real JWT/DB/Redis passwords.
# =============================================================================

BIND_HOST=127.0.0.1
SERVER_PORT=8085
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai
LOG_LEVEL=info
LOG_FORMAT=json

# Admin (set on server only)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=

# Secrets — generate with: openssl rand -hex 32
JWT_SECRET=
TOTP_ENCRYPTION_KEY=
POSTGRES_PASSWORD=
REDIS_PASSWORD=

POSTGRES_USER=sub2api
POSTGRES_DB=sub2api
DATABASE_PORT=5432
DATABASE_MAX_OPEN_CONNS=40
DATABASE_MAX_IDLE_CONNS=10

REDIS_PORT=6379
REDIS_DB=0
REDIS_POOL_SIZE=128
REDIS_MIN_IDLE_CONNS=4

# Docker publishes to host; app trusts Nginx via docker bridge gateway
SERVER_TRUSTED_PROXIES=172.18.0.1

SECURITY_URL_ALLOWLIST_ENABLED=true
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=false
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=false
SECURITY_URL_ALLOWLIST_UPSTREAM_HOSTS=api.openai.com,api.anthropic.com,api.kimi.com,open.bigmodel.cn,api.minimaxi.com,generativelanguage.googleapis.com,cloudcode-pa.googleapis.com,api.x.ai,api.github.com,api.githubcopilot.com,api.individual.githubcopilot.com,api.business.githubcopilot.com,*.openai.azure.com

CORS_ALLOWED_ORIGINS=https://3api.shop,https://sub2api-cj7.pages.dev
CORS_ALLOW_CREDENTIALS=true

UPDATE_PROXY_URL=

# Pin image after successful production-deploy.sh
# SUB2API_IMAGE=ghcr.io/tii-mom/3@sha256:<digest>
